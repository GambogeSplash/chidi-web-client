# =============================================================================
# Chidi Web Client - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# =============================================================================
# API BACKEND
# =============================================================================
# Local development:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Production (Railway deployed backend):
NEXT_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app

# =============================================================================
# SUPABASE (Client-side)
# =============================================================================
# Get these from: Supabase Dashboard → Settings → API
# Only use the ANON key on the client side (never the service role key!)

NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# VERCEL ANALYTICS (optional)
# =============================================================================
# Automatically configured when deployed to Vercel
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# =============================================================================
# SENTRY (error tracking)
# =============================================================================
# Get your DSN from: Sentry Dashboard → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Required for source map uploads during CI builds:
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
